# Docker Compose secrets are expected under ./secrets:
# - secrets/openai_api_key.txt
# - secrets/openai_api_base.txt
# - secrets/openai_model_name.txt

# Optional post-process finalization overrides:
# - GIT_PUSH_REMOTE=<remote name or direct URL/path>
# - GIT_PUSH_BRANCH=<destination branch>
# - TRELLO_DONE_LIST_ID=<explicit done list id>
# - TRELLO_DONE_LIST_NAME=<done list name fallback, e.g. 完成>
