{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://argus.local/contracts/task.schema.json",
  "title": "Argus task.json",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "type"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^artifacts/"
        },
        "type": {
          "type": "string",
          "enum": ["architecture", "script", "config", "review", "doc"]
        }
      }
    }
  },
  "required": [
    "task_id",
    "worker",
    "task_type",
    "objective",
    "inputs",
    "expected_outputs",
    "constraints"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^(ARCH|DEVOPS|AUTO|CRITIC)-[0-9]{8}-[0-9]{3}$"
    },
    "worker": {
      "type": "string",
      "enum": ["architect", "devops", "automation", "critic"]
    },
    "task_type": {
      "type": "string",
      "enum": ["design_architecture", "setup_infrastructure", "generate_script", "review_artifact"]
    },
    "objective": {
      "type": "string",
      "minLength": 10
    },
    "inputs": {
      "type": "object",
      "description": "Task-specific inputs translated by Manager.",
      "properties": {
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "params": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "medium"
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["simulated_trello", "trello", "manual", "internal", "local_inbox"]
        },
        "card_id": {
          "type": "string"
        },
        "card_title": {
          "type": "string"
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "worker": { "const": "architect" }
        }
      },
      "then": {
        "properties": {
          "task_id": {
            "pattern": "^ARCH-[0-9]{8}-[0-9]{3}$"
          },
          "task_type": {
            "const": "design_architecture"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "worker": { "const": "devops" }
        }
      },
      "then": {
        "properties": {
          "task_id": {
            "pattern": "^DEVOPS-[0-9]{8}-[0-9]{3}$"
          },
          "task_type": {
            "const": "setup_infrastructure"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "worker": { "const": "automation" }
        }
      },
      "then": {
        "properties": {
          "task_id": {
            "pattern": "^AUTO-[0-9]{8}-[0-9]{3}$"
          },
          "task_type": {
            "const": "generate_script"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "worker": { "const": "critic" }
        }
      },
      "then": {
        "properties": {
          "task_id": {
            "pattern": "^CRITIC-[0-9]{8}-[0-9]{3}$"
          },
          "task_type": {
            "const": "review_artifact"
          }
        }
      }
    }
  ]
}
